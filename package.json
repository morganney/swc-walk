{
  "name": "swc-walk",
  "version": "2.1.1",
  "description": "Walk an AST from SWC and visit each node type.",
  "main": "dist/esm/walk.js",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/walk.d.ts",
        "default": "./dist/esm/walk.js"
      },
      "require": {
        "types": "./dist/cjs/walk.d.cts",
        "default": "./dist/cjs/walk.cjs"
      },
      "default": "./dist/esm/walk.js"
    },
    "./baseVisitor": {
      "import": {
        "types": "./dist/esm/baseVisitor.d.ts",
        "default": "./dist/esm/baseVisitor.js"
      },
      "require": {
        "types": "./dist/cjs/baseVisitor.d.cts",
        "default": "./dist/cjs/baseVisitor.cjs"
      },
      "default": "./dist/esm/baseVisitor.js"
    },
    "./types": {
      "import": {
        "types": "./dist/esm/types.d.ts",
        "default": "./dist/esm/types.js"
      },
      "require": {
        "types": "./dist/cjs/types.d.cts",
        "default": "./dist/cjs/types.cjs"
      },
      "default": "./dist/esm/types.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#swc-walk": "./src/walk.ts",
    "#swc-walk/baseVisitor": "./src/baseVisitor.ts",
    "#swc-walk/types": "./src/types.ts"
  },
  "engines": {
    "node": ">=22.21.1 <23 || >=24 <25 || >=26 <27"
  },
  "engineStrict": true,
  "scripts": {
    "check-types": "tsc -p tsconfig.eslint.json",
    "prettier": "prettier -w .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build": "duel --dirs",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcov tsx --test --test-reporter=spec test/*.test.ts",
    "prepack": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "swc",
    "ast",
    "walk",
    "visitor",
    "traverse",
    "acorn-walk"
  ],
  "author": "Morgan Ney <morganney@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morganney/swc-walk.git"
  },
  "bugs": {
    "url": "https://github.com/morganney/swc-walk/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@knighted/duel": "^4.1.0",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@swc/core": "^1.15.43",
    "@swc/types": "^0.1.27",
    "@types/node": "^25.9.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-n": "^18.0.1",
    "prettier": "^3.6.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "acorn-walk": "^8.3.5"
  },
  "overrides": {
    "c8": {
      "yargs": ">17.7.2 <19"
    }
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 119,
    "semi": false,
    "singleQuote": true
  }
}
